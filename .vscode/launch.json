{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Batch Run (urls.txt)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/batch_run.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Run Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }
    ]
}
